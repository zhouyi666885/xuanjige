# ============================================================
# 玄机阁 - 独立部署环境变量配置
# 复制本文件为 .env，填入真实凭证
# ============================================================

# ===== 服务端口 =====
PORT=5000
HOST_PORT=80

# ===== LLM API（必填）=====
# 推荐用阿里云百炼（通义千问）—— 与 OpenAI 协议兼容
LLM_API_KEY=你的-阿里云百炼-API-KEY
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 备选 1：豆包（火山方舟 ARK）
# LLM_API_KEY=你的-火山方舟-API-KEY
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=doubao-seed-1-6-pro

# 备选 2：DeepSeek
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 备选 3：OpenAI
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ===== 网络搜索（用于自动录入书籍）=====
SEARCH_PROVIDER=serper
SEARCH_API_KEY=你的-serper-key
# 备选：bing (Azure) / tavily / none(禁用搜索)

# ===== Supabase 数据库（必填）=====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ===== 对象存储（可选，不填走本地兜底）=====
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ===== 公开访问域名（可选，影响分享链接）=====
COZE_PROJECT_DOMAIN_DEFAULT=
